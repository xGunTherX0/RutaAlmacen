<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/texto_producto_alerta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleMedium"
            android:textStyle="bold"
            android:text="Producto" />

        <TextView
            android:id="@+id/texto_detalle_alerta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:text="Alta demanda en tu zona" />

        <TextView
            android:id="@+id/texto_metrica_alerta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:text="Busquedas: 0 • Radio aprox: 0 m" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
