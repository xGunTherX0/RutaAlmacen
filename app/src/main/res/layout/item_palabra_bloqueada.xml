<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/espacio_xs"
    android:layout_marginVertical="@dimen/espacio_xs"
    app:cardBackgroundColor="@color/fondo_card"
    app:cardCornerRadius="@dimen/radio_card"
    app:cardElevation="@dimen/elevacion_card"
    app:cardUseCompatPadding="true"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/padding_card">

        <TextView
            android:id="@+id/texto_palabra_bloqueada"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleMedium"
            android:text="Palabra" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_eliminar_palabra"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@android:drawable/ic_menu_delete"
            android:text="Eliminar" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
