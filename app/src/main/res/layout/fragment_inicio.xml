<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_inicio"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Cabecera de Perfil -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imagen_perfil"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay_RutaAlmacen_Circle"
                tools:src="@android:drawable/sym_def_app_icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/texto_saludo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Hola,"
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
                    android:textColor="@color/texto_secundario" />

                <TextView
                    android:id="@+id/texto_nombre_usuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuario"
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.HeadlineMedium"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/icono_notificaciones"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="Notificaciones"
                android:padding="8dp"
                android:src="@drawable/ic_notifications_none"
                app:tint="@color/texto_secundario" />
        </LinearLayout>

        <!-- Tarjeta de Estado del Almacén -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tarjeta_estado_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/fondo_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/icono_plan"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="Plan actual"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/colorPrimary" />

                    <TextView
                        android:id="@+id/texto_titulo_plan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Estado de tu Almacén"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleMedium"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/texto_nombre_plan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Plan: Cargando..."
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyLarge" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/texto_productos_activos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 / 0 productos"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
                        android:textColor="@color/texto_secundario" />

                    <TextView
                        android:id="@+id/texto_porcentaje"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/barra_progreso_productos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:trackThickness="8dp"
                    app:trackCornerRadius="4dp"
                    app:indicatorColor="@color/colorPrimary"
                    app:trackColor="@color/colorPrimaryLight"
                    tools:progress="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tarjeta de Anuncio AdMob -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tarjeta_anuncio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="visible"
            app:cardBackgroundColor="#FFF8F9FA"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Recomendado para ti"
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodySmall"
                    android:textColor="@color/texto_terciario"
                    android:textStyle="italic" />

                <com.google.android.gms.ads.AdView
                    android:id="@+id/ad_view_inicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:adSize="MEDIUM_RECTANGLE"
                    app:adUnitId="ca-app-pub-3940256099942544/6300978111" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sección de Accesos Rápidos -->
        <TextView
            android:id="@+id/texto_titulo_accesos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Accesos Rápidos"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleMedium"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contenedor_accesos_rapidos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="80dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tarjeta_nueva_venta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/colorPrimaryLight"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="Nueva Venta"
                        android:src="@android:drawable/ic_menu_add"
                        app:tint="@color/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Nueva Venta"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tarjeta_bloc_notas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#FFFEF3C7"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="Bloc de Notas"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="#FFB8860B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Bloc de Notas"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
