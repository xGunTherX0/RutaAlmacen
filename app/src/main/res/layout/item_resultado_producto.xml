<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tarjeta_resultado"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/espacio_xs"
    android:layout_marginVertical="@dimen/espacio_xs"
    app:cardBackgroundColor="@color/fondo_card"
    app:cardCornerRadius="@dimen/radio_card"
    app:cardElevation="@dimen/elevacion_card"
    app:cardUseCompatPadding="true"
    app:strokeWidth="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_card">

            <TextView
                android:id="@+id/texto_nombre_producto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="60dp"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleMedium"
                android:text="Nombre del producto" />

            <LinearLayout
                android:id="@+id/contenedor_precio_oferta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/texto_precio_oferta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/oferta_precio"
                    android:textSize="@dimen/texto_titulo_lg"
                    android:textStyle="bold"
                    tools:text="$2400" />

                <TextView
                    android:id="@+id/texto_unidad_oferta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/espacio_xs"
                    android:textColor="@color/texto_secundario"
                    android:textSize="@dimen/texto_cuerpo_md"
                    tools:text="/ unidad" />
            </LinearLayout>

            <TextView
                android:id="@+id/texto_precio_producto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xxs"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:text="Precio: $0" />

            <TextView
                android:id="@+id/texto_tiempo_restante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:background="@drawable/bg_tiempo_oferta"
                android:drawableStart="@drawable/ic_clock"
                android:drawablePadding="6dp"
                android:drawableTint="@color/oferta_tiempo_texto"
                android:gravity="center_vertical"
                android:textColor="@color/oferta_tiempo_texto"
                android:textSize="@dimen/texto_cuerpo_sm"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="¡Quedan 4 horas!"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/texto_descripcion_producto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:text="Descripción: -" />

            <TextView
                android:id="@+id/texto_almacen_producto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:text="Almacén: Sin nombre" />

            <TextView
                android:id="@+id/texto_horario_almacen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:text="Horario: 09:00 - 13:00 / 16:00 - 22:00" />

            <TextView
                android:id="@+id/texto_estado_horario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:text="Atención: Abierto" />

            <TextView
                android:id="@+id/texto_distancia_producto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:text="Distancia: --" />

            <TextView
                android:id="@+id/texto_estado_producto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:text="Estado: Disponible" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_md"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_ver_stock"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver stock" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_llegar_almacen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/espacio_sm"
                    android:text="Llegar" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/badge_descuento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="@dimen/espacio_sm"
            android:layout_marginEnd="@dimen/espacio_sm"
            android:background="@drawable/bg_descuento_badge"
            android:elevation="2dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textColor="@color/oferta_descuento_texto"
            android:textSize="@dimen/texto_cuerpo_md"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="-20% OFF"
            tools:visibility="visible" />
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
