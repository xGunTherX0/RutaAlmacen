<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_planes"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margen_pantalla">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_planes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/ic_volver"
            app:title="Planes y suscripción" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/separador_card"
            app:cardBackgroundColor="@color/fondo_card"
            app:cardCornerRadius="@dimen/radio_card"
            app:cardElevation="@dimen/elevacion_card"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <TextView
                    android:id="@+id/texto_plan_actual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cargando tu plan actual..."
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleMedium" />

                <TextView
                    android:id="@+id/texto_uso_actual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/espacio_xs"
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_lg"
            android:text="Elige un plan"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleLarge" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_planes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/separador_card"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_lg"
            android:text="Pagos seguros con Google Play"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodySmall" />

        <TextView
            android:id="@+id/texto_terminos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xs"
            android:text="Las suscripciones se renuevan automáticamente al final de cada ciclo. Puedes cancelar en cualquier momento desde tu cuenta de Google Play."
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodySmall" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
