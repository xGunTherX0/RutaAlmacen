<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/espacio_xs"
    android:layout_marginVertical="@dimen/espacio_xs"
    app:cardBackgroundColor="@color/fondo_card"
    app:cardCornerRadius="@dimen/radio_card"
    app:cardElevation="@dimen/elevacion_card"
    app:cardUseCompatPadding="true"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/texto_nombre_almacen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleMedium"
                android:text="Almacén" />

            <TextView
                android:id="@+id/texto_estado_almacen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:textColor="@color/estado_abierto"
                android:textStyle="bold"
                android:text="Abierto" />
        </LinearLayout>

        <TextView
            android:id="@+id/texto_distancia_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_sm"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
            android:text="Distancia: 0 m" />

        <TextView
            android:id="@+id/texto_categoria_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xs"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
            android:text="Categoría: Almacén" />

        <TextView
            android:id="@+id/texto_horario_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xs"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
            android:text="Horario: 09:00 - 13:00 / 15:00 - 19:00" />

        <TextView
            android:id="@+id/texto_pagos_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xs"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
            android:text="Pagos: " />

        <TextView
            android:id="@+id/texto_caja_vecina_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xxs"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
            android:textStyle="bold"
            android:text="Caja Vecina: " />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_md"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_ver_stock_almacen"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ver stock" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_llegar_almacen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/espacio_sm"
                android:layout_weight="1"
                android:text="Llegar" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
