<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_plan"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/espacio_xs"
    android:layout_marginVertical="@dimen/espacio_xs"
    app:cardBackgroundColor="@color/fondo_card"
    app:cardCornerRadius="@dimen/radio_card"
    app:cardElevation="@dimen/elevacion_card"
    app:cardUseCompatPadding="true"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/texto_nombre_plan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleLarge" />

            <TextView
                android:id="@+id/chip_plan_actual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_actual"
                android:paddingHorizontal="@dimen/espacio_md"
                android:paddingVertical="@dimen/espacio_xs"
                android:text="Actual"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodySmall"
                android:textColor="@color/white"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/texto_descripcion_plan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xs"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:textColor="@color/texto_secundario" />

        <TextView
            android:id="@+id/texto_precio_plan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/separador_card"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.HeadlineSmall"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/texto_periodo_plan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodySmall"
            android:textColor="@color/texto_secundario" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/separador_card"
            android:text="Incluye"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/texto_max_productos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xxs"
            android:drawablePadding="@dimen/espacio_sm"
            android:drawableStart="@drawable/ic_check"
            android:gravity="center_vertical"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

        <TextView
            android:id="@+id/texto_max_alertas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xxs"
            android:drawablePadding="@dimen/espacio_sm"
            android:drawableStart="@drawable/ic_check"
            android:gravity="center_vertical"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

        <TextView
            android:id="@+id/texto_funciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xxs"
            android:drawablePadding="@dimen/espacio_sm"
            android:drawableStart="@drawable/ic_check"
            android:gravity="center_vertical"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

        <TextView
            android:id="@+id/texto_almacenes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xxs"
            android:drawablePadding="@dimen/espacio_sm"
            android:drawableStart="@drawable/ic_check"
            android:gravity="center_vertical"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_seleccionar_plan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_lg"
            android:text="Elegir este plan" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
