<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/espacio_xs"
    android:layout_marginVertical="@dimen/espacio_xs"
    app:cardBackgroundColor="@color/fondo_card"
    app:cardCornerRadius="@dimen/radio_card"
    app:cardElevation="@dimen/elevacion_card"
    app:cardUseCompatPadding="true"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/texto_nombre_producto_admin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleMedium"
                android:text="Nombre del producto" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_categoria_producto_admin"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="false"
                android:clickable="false"
                android:text="Categoría" />
        </LinearLayout>

        <TextView
            android:id="@+id/texto_precio_producto_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_sm"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:text="Precio: $0" />

        <TextView
            android:id="@+id/texto_descripcion_producto_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xs"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:text="Descripción: -" />

        <TextView
            android:id="@+id/texto_estado_producto_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xs"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:text="Estado: Disponible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_md"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_editar_producto_admin"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@android:drawable/ic_menu_edit"
                android:text="Editar" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_eliminar_producto_admin"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/espacio_sm"
                app:icon="@android:drawable/ic_menu_delete"
                android:text="Eliminar"
                android:textColor="@color/estado_cerrado" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
