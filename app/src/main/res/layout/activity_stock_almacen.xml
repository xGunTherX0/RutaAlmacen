<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contenedor_stock_almacen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app"
    android:padding="@dimen/margen_pantalla"
    tools:context=".StockAlmacenActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contenedor_header_stock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/fondo_card"
        app:cardCornerRadius="@dimen/radio_card"
        app:cardElevation="@dimen/elevacion_card"
        app:cardUseCompatPadding="true"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/padding_card">

            <TextView
                android:id="@+id/texto_titulo_stock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Stock del almacén"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleLarge" />

            <TextView
                android:id="@+id/texto_nombre_almacen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_sm"
                android:gravity="center"
                android:text="Almacén"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium" />

            <TextView
                android:id="@+id/texto_horario_almacen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:gravity="center"
                android:text="Horario: 09:00 - 13:00 / 16:00 - 22:00"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_llegar_almacen_stock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_md"
                android:text="Llegar al almacén" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contenedor_info_pagos_stock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_md"
        app:cardBackgroundColor="@color/fondo_card"
        app:cardCornerRadius="@dimen/radio_card"
        app:cardElevation="@dimen/elevacion_card"
        app:cardUseCompatPadding="true"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_header_stock">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_card">

            <TextView
                android:id="@+id/texto_pagos_almacen_stock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💳 Pagos: "
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium" />

            <TextView
                android:id="@+id/texto_caja_vecina_stock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/espacio_xs"
                android:text="🏪 Caja Vecina: "
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/contenedor_busqueda_stock"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_lg"
        android:hint="Buscar producto del almacén"
        app:hintTextAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_info_pagos_stock">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/campo_busqueda_stock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionSearch"
            android:inputType="textCapWords" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/contenedor_categoria_stock"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_md"
        android:hint="Categoría"
        app:endIconMode="dropdown_menu"
        app:hintTextAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_busqueda_stock">

        <AutoCompleteTextView
            android:id="@+id/campo_categoria_stock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/texto_resultados_stock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_lg"
        android:text="Resultados"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_categoria_stock" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_stock"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/espacio_sm"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/espacio_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_resultados_stock"
        tools:listitem="@layout/item_stock_almacen" />

</androidx.constraintlayout.widget.ConstraintLayout>
