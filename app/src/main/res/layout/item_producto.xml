<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tarjeta_producto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/espacio_xs"
    android:layout_marginVertical="@dimen/espacio_xs"
    app:cardBackgroundColor="@color/fondo_card"
    app:cardCornerRadius="@dimen/radio_card"
    app:cardElevation="@dimen/elevacion_card"
    app:cardUseCompatPadding="true"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/texto_nombre_producto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/espacio_sm"
                android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleMedium"
                android:textSize="@dimen/texto_titulo_sm"
                android:maxLines="1"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="Nombre del producto" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_categoria_producto"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="false"
                android:clickable="false"
                android:textSize="@dimen/texto_cuerpo_md"
                app:ensureMinTouchTargetSize="false"
                android:text="Categoría" />
        </LinearLayout>

        <TextView
            android:id="@+id/badge_oferta_activa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xs"
            android:background="@drawable/bg_oferta_badge"
            android:drawableStart="@drawable/ic_local_offer"
            android:drawablePadding="6dp"
            android:drawableTint="@color/oferta_texto"
            android:gravity="center_vertical"
            android:text="Oferta activa"
            android:textColor="@color/oferta_texto"
            android:textSize="@dimen/texto_cuerpo_sm"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/texto_precio_producto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_sm"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:text="Precio: $0" />

        <TextView
            android:id="@+id/texto_oferta_resumen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_xxs"
            android:textColor="@color/oferta_precio"
            android:textSize="@dimen/texto_cuerpo_md"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="Oferta: $2400 · vence en 3 h"
            tools:visibility="visible" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_disponible_producto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_md"
            android:text="Disponible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_md"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_editar_producto"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:maxLines="1"
                android:singleLine="true"
                android:textSize="@dimen/texto_cuerpo_sm"
                app:iconSize="14dp"
                app:iconPadding="2dp"
                app:icon="@android:drawable/ic_menu_edit"
                android:text="Editar" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_oferta_producto"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/espacio_xs"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:maxLines="1"
                android:singleLine="true"
                android:textSize="@dimen/texto_cuerpo_sm"
                android:textColor="@color/oferta_texto"
                app:iconSize="14dp"
                app:iconPadding="2dp"
                app:iconTint="@color/oferta_texto"
                app:icon="@drawable/ic_local_offer"
                android:text="Oferta" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_eliminar_producto"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/espacio_xs"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:maxLines="1"
                android:singleLine="true"
                android:textSize="@dimen/texto_cuerpo_sm"
                app:iconSize="14dp"
                app:iconPadding="2dp"
                app:icon="@android:drawable/ic_menu_delete"
                android:text="Eliminar"
                android:textColor="@color/estado_cerrado" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
