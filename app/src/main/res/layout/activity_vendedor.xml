<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contenedor_vendedor"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".VendedorActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/contenedor_fragmentos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nav_vendedor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_vendedor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:itemIconSize="28dp"
        app:itemTextAppearanceActive="@style/TextAppearance.RutaAlmacen.Vendedor.Nav"
        app:itemTextAppearanceInactive="@style/TextAppearance.RutaAlmacen.Vendedor.Nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_vendedor" />

</androidx.constraintlayout.widget.ConstraintLayout>
