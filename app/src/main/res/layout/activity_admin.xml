<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contenedor_admin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app"
    android:padding="@dimen/margen_pantalla"
    tools:context=".AdminActivity">

    <TextView
        android:id="@+id/texto_titulo_admin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Panel de administrador"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleLarge"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/texto_detalle_admin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_xs"
        android:text="Gestión de usuarios y stock de vendedores."
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_titulo_admin" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/contenedor_busqueda_usuario"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/separador_card"
        android:hint="Buscar por nombre o correo"
        app:hintTextAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_detalle_admin">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/campo_busqueda_usuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/contenedor_filtro_rol"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/separador_card"
        android:hint="Filtrar por rol"
        app:endIconMode="dropdown_menu"
        app:hintTextAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_busqueda_usuario">

        <AutoCompleteTextView
            android:id="@+id/campo_filtro_rol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contenedor_acciones_admin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/separador_card"
        app:cardBackgroundColor="@color/fondo_card"
        app:cardCornerRadius="@dimen/radio_card"
        app:cardElevation="@dimen/elevacion_card"
        app:cardUseCompatPadding="true"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_filtro_rol">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_card">

            <LinearLayout
                android:id="@+id/encabezado_acciones_admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Acciones"
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleMedium" />

                <ImageView
                    android:id="@+id/icono_acciones_admin"
                    android:layout_width="@dimen/ancho_icono"
                    android:layout_height="@dimen/ancho_icono"
                    android:contentDescription="@null"
                    android:src="@android:drawable/arrow_down_float" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/contenido_acciones_admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/separador_card"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_palabras_bloqueadas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Palabras bloqueadas"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_alertas_reportadas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/espacio_sm"
                    android:text="Alertas reportadas"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_estadisticas_planes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/espacio_sm"
                    android:text="Estadísticas de Planes"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_promover_admin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/espacio_sm"
                    android:text="Promover a Administrador"
                    app:iconGravity="textStart" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/texto_sin_usuarios"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/separador_card"
        android:text="No hay usuarios registrados."
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_acciones_admin" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_usuarios_admin"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/separador_card"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/espacio_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_sin_usuarios"
        tools:listitem="@layout/item_usuario_admin" />

</androidx.constraintlayout.widget.ConstraintLayout>
