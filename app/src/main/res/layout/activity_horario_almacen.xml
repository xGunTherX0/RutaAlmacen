<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contenedor_horario_almacen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="20dp"
    tools:context=".HorarioAlmacenActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/texto_titulo_horario_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Horario de atención"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.TitleLarge"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/texto_descripcion_horario_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Configura los turnos de tu almacén."
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

        <TextView
            android:id="@+id/texto_horario_almacen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Horario de atención: 09:00 - 13:00 / 16:00 - 22:00"
            android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Turno mañana - inicio"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/boton_horario_manana_inicio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09:00" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Turno mañana - fin"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/boton_horario_manana_fin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="13:00" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Turno tarde - inicio"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/boton_horario_tarde_inicio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="16:00" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Turno tarde - fin"
                        android:textAppearance="@style/TextAppearance.RutaAlmacen.Vendedor.BodyMedium" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/boton_horario_tarde_fin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22:00" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_guardar_horario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Guardar horario"
            android:textSize="17sp" />
    </LinearLayout>
</ScrollView>
