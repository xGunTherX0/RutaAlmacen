<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contenedor_comprador"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app"
    android:paddingHorizontal="@dimen/margen_pantalla"
    android:paddingTop="@dimen/espacio_sm"
    android:paddingBottom="@dimen/espacio_xs"
    tools:context=".CompradorActivity">

    <TextView
        android:id="@+id/texto_titulo_comprador"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Buscar productos"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleLarge"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contenedor_busqueda_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_sm"
        app:cardBackgroundColor="@color/fondo_card"
        app:cardCornerRadius="@dimen/radio_card"
        app:cardElevation="@dimen/elevacion_card"
        app:cardUseCompatPadding="false"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_titulo_comprador">

        <LinearLayout
            android:id="@+id/fila_busqueda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/espacio_sm"
            android:paddingVertical="@dimen/espacio_xs">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/contenedor_busqueda"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nombre del producto"
                app:hintTextAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campo_busqueda_producto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionSearch"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_info_alertas"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="@dimen/alto_boton_pequeno"
                android:layout_height="@dimen/alto_boton_pequeno"
                android:layout_marginStart="@dimen/espacio_sm"
                android:minWidth="0dp"
                android:text="?"
                app:cornerRadius="@dimen/radio_boton" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/boton_buscar_producto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_sm"
        android:text="Buscar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_busqueda_card" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contenedor_filtros"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_sm"
        app:cardBackgroundColor="@color/fondo_card"
        app:cardCornerRadius="@dimen/radio_card"
        app:cardElevation="@dimen/elevacion_card"
        app:cardUseCompatPadding="false"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/boton_buscar_producto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/espacio_sm"
            android:paddingVertical="@dimen/espacio_xs">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/contenedor_categoria"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Categoría"
                app:endIconMode="dropdown_menu"
                app:hintTextAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium">

                <AutoCompleteTextView
                    android:id="@+id/campo_categoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/texto_resultados"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_sm"
        android:text="Resultados"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_filtros" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_resultados"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/espacio_xs"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/espacio_lg"
        app:layout_constraintBottom_toTopOf="@id/nav_comprador"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_resultados"
        tools:listitem="@layout/item_resultado_producto" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_comprador"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/fondo_card"
        app:itemIconSize="@dimen/ancho_icono_grande"
        app:itemIconTint="@color/colorPrimary"
        app:itemTextAppearanceActive="@style/TextAppearance.RutaAlmacen.Comprador.Nav"
        app:itemTextAppearanceInactive="@style/TextAppearance.RutaAlmacen.Comprador.Nav"
        app:itemTextColor="@color/colorPrimary"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/menu_comprador" />

    <LinearLayout
        android:id="@+id/contenedor_carga_comprador"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/fondo_card"
            app:cardCornerRadius="@dimen/radio_card"
            app:cardElevation="@dimen/elevacion_card"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="@dimen/espacio_3xl"
                    android:layout_height="@dimen/espacio_3xl"
                    app:indicatorSize="@dimen/espacio_3xl"
                    app:trackThickness="@dimen/espacio_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/espacio_sm"
                    android:text="Cargando..."
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
