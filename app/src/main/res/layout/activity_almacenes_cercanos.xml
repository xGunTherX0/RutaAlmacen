<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contenedor_almacenes"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_app"
    android:padding="@dimen/margen_pantalla"
    tools:context=".AlmacenesCercanosActivity">

    <TextView
        android:id="@+id/texto_titulo_almacenes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Buscar almacenes"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleLarge"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contenedor_filtro_distancia_almacenes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_lg"
        app:cardBackgroundColor="@color/fondo_card"
        app:cardCornerRadius="@dimen/radio_card"
        app:cardElevation="@dimen/elevacion_card"
        app:cardUseCompatPadding="true"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_titulo_almacenes">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_card">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/contenedor_categoria_almacenes"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Categoría del almacén"
                app:endIconMode="dropdown_menu"
                app:hintTextAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium">

                <AutoCompleteTextView
                    android:id="@+id/campo_categoria_almacenes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/texto_sin_almacenes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_lg"
        android:gravity="center"
        android:text="No se encontraron almacenes"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_filtro_distancia_almacenes" />

    <TextView
        android:id="@+id/texto_resultados_almacenes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/espacio_lg"
        android:text="Resultados"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_filtro_distancia_almacenes" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_almacenes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/espacio_sm"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/espacio_lg"
        app:layout_constraintBottom_toTopOf="@id/nav_comprador"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_resultados_almacenes"
        tools:listitem="@layout/item_almacen_cercano" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_comprador"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/fondo_card"
        app:itemIconSize="@dimen/ancho_icono_grande"
        app:itemIconTint="@color/colorPrimary"
        app:itemTextAppearanceActive="@style/TextAppearance.RutaAlmacen.Comprador.Nav"
        app:itemTextAppearanceInactive="@style/TextAppearance.RutaAlmacen.Comprador.Nav"
        app:itemTextColor="@color/colorPrimary"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/menu_comprador" />

    <LinearLayout
        android:id="@+id/contenedor_carga_almacenes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/fondo_card"
            app:cardCornerRadius="@dimen/radio_card"
            app:cardElevation="@dimen/elevacion_card"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="@dimen/espacio_3xl"
                    android:layout_height="@dimen/espacio_3xl"
                    app:indicatorSize="@dimen/espacio_3xl"
                    app:trackThickness="@dimen/espacio_xs" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/espacio_sm"
                    android:text="Cargando..."
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
