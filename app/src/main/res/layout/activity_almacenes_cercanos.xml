<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contenedor_almacenes"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".AlmacenesCercanosActivity">

    <TextView
        android:id="@+id/texto_titulo_almacenes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Buscar almacenes"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleLarge"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contenedor_filtro_distancia_almacenes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_titulo_almacenes">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/encabezado_distancia_almacenes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rango de distancia"
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/icono_distancia_almacenes"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@android:drawable/arrow_down_float" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/contenido_distancia_almacenes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/texto_distancia_almacenes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Distancia: hasta 100 km"
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/grupo_distancia_almacenes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:selectionRequired="true"
                    app:singleSelection="true" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/contenedor_categoria_almacenes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Categoría del almacén"
                    app:endIconMode="dropdown_menu"
                    app:hintTextAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium">

                    <AutoCompleteTextView
                        android:id="@+id/campo_categoria_almacenes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textSize="17sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/texto_resultados_almacenes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Resultados"
        android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.TitleMedium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/contenedor_filtro_distancia_almacenes" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_almacenes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/nav_comprador"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/texto_resultados_almacenes"
        tools:listitem="@layout/item_almacen_cercano" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_comprador"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:itemIconSize="26dp"
        app:itemTextAppearanceActive="@style/TextAppearance.RutaAlmacen.Comprador.Nav"
        app:itemTextAppearanceInactive="@style/TextAppearance.RutaAlmacen.Comprador.Nav"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/menu_comprador" />

    <LinearLayout
        android:id="@+id/contenedor_carga_almacenes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:indicatorSize="36dp"
                    app:trackThickness="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Cargando..."
                    android:textAppearance="@style/TextAppearance.RutaAlmacen.Comprador.BodyMedium" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
